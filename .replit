# БЛОК ЗАПУСКА ПРИЛОЖЕНИЯ
# Команда для запуска Django-сервера
# python - запускает интерпретатор Python
# manage.py - главный скрипт управления Django
# runserver - команда запуска встроенного веб-сервера
# 0.0.0.0:3000 - слушает все сетевые интерфейсы на порту 3000
run = ["python", "manage.py", "runserver", "0.0.0.0:3000"]
# БЛОК ТОЧКИ ВХОДА
# Указывает главный файл проекта, который будет выполнен при запуске
entrypoint = "manage.py"
# БЛОК МОДУЛЕЙ И ВЕРСИЙ
# Список установленных модулей и их версий
# python-3.10:v18-20230807-322e88b - версия Python 3.10 с фиксированным образом
modules = ["python-3.10:v18-20230807-322e88b"]
# БЛОК СКРЫТЫХ ФАЙЛОВ И ПАПОК
# Папки, которые не отображаются в файловом менеджере Replit
# .pythonlibs - библиотеки Python, установленные в виртуальное окружение
hidden = [".pythonlibs"]
# БЛОК НАСТРОЕК Nix (ПАКЕТНЫЙ МЕНЕДЖЕР)
[nix]
# Канал Nixpkgs - стабильная версия от мая 2024 года
# Используется для управления системными зависимостями
channel = "stable-24_05"
# БЛОК НАСТРОЕК МОДУЛЬНОГО ТЕСТИРОВАНИЯ
[unitTest]
# Язык для модульных тестов (используется pytest)
language = "python3"
# БЛОК НАСТРОЕК РАЗВЁРТЫВАНИЯ (DEPLOYMENT)
[deployment]
# Команда запуска при развёртывании на удалённом сервере
run = ["python", "manage.py", "runserver", "0.0.0.0:3000"]
# Цель развёртывания: Google Compute Engine (облачная платформа Google)
deploymentTarget = "gce"
# БЛОК ПРОБРОСА ПОРТОВ
[[ports]]
# Локальный порт внутри контейнера (приложение слушает здесь)
localPort = 3000
# Внешний порт (доступен из интернета)
# 80 - стандартный HTTP-порт, не требует указания порта в URL
externalPort = 80
# БЛОК НАСТРОЕК АГЕНТА (ИНТЕЛЛЕКТУАЛЬНОГО ПОМОЩНИКА)
[agent]
# Расширенный режим работы ИИ-помощника в Replit
expertMode = true
